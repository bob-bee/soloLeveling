# ====================================================================
# PROJECT PIPELINE REGULATORS (MANGA EXTRACTOR SPECS)
# ====================================================================

# Step 1: Ignore everything inside the output folder completely
output/*

# Step 2: Un-ignore / allow tracking of specific viewer core engine files
!output/viewer.html

# ====================================================================
# STANDARD SYSTEM & ENVIRONMENT IGNORES
# ====================================================================

# Python bytecode & cache systems
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment wrappers
.venv/
.devcontainer/
.env/
env/

# IDE files (VS Code / PyCharm / Sublime)
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.ipynb_checkpoints/

# Development artifacts & diagnostic reports
*.log
*.tmp
test_output/
test_results/
.coverage
coverage.xml
htmlcov/

# Deployment & compilation frames
Dockerfile*
docker-compose.yml
dist/
build/
*.egg-info/
*.egg
*.whl